# LLM Provider Configuration
# Options: "ollama" or "gemini"
LLM_PROVIDER=gemini

# Default model to use. This model does ALL scoring and regrading
# (score.py and reflow.py --candidate), so keep it pinned to the same
# model across runs if you want scores to stay comparable over time.
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
DEFAULT_MODEL=gemini-2.5-flash

# Google Gemini API Key (required if using a Gemini model)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key — OPTIONAL. Only needed if you set
# DEFAULT_MODEL to a Claude model. reflow.py no longer calls the Claude
# API for tailoring: tailored content is written by the calling agent
# (e.g. the Claude chat running the resume-reflow-pipeline skill) and
# reflow.py only validates and regrades it.
# CLAUDE_API_KEY=your_claude_api_key_here
