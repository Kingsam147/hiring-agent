# LLM Provider Configuration
# Options: "ollama" or "gemini"
LLM_PROVIDER=ollama

# Default model to use
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
DEFAULT_MODEL=gemma3:4b

# Google Gemini API Key (required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Proactive client-side pacing for Gemini API calls (free tier is commonly
# ~10 RPM for flash models, lower for pro -- check aistudio.google.com for
# current limits). Set to 0 or a negative number to disable pacing. Has no
# effect on Ollama.
GEMINI_REQUESTS_PER_MINUTE=8

# Local daily budget for real Gemini API calls (free tier is 20/day for
# gemini-2.5-flash: quota GenerateRequestsPerDayPerProjectPerModel-FreeTier).
# Tracked per model per UTC day in cache/gemini_quota_*.json. When the count
# reaches this budget, calls fail fast instead of hitting the API. Set to 0
# or a negative number to disable the guard. Has no effect on Ollama.
GEMINI_REQUESTS_PER_DAY=20
